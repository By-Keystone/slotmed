datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

model User {
  id         Int       @id @default(autoincrement())
  name       String
  last_name  String
  phone      String    @unique
  email      String    @unique
  auth_id    String
  active     Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz()
  updated_at DateTime? @db.Timestamptz()
  deleted_at DateTime? @db.Timestamptz()

  sedes             UserSedes[] @relation("UserSedeMember")
  sedes_assignments UserSedes[] @relation("UserSedeAssignedBy")
  doctor            Doctor?

  @@map("user")
}

model Sede {
  id         Int         @id @default(autoincrement())
  name       String
  address    String
  contacts   UserSedes[]
  doctors    Doctor[]
  active     Boolean     @default(true)
  created_at DateTime    @default(now()) @db.Timestamptz()
  updated_at DateTime?   @db.Timestamptz()
  deleted_at DateTime?   @db.Timestamptz()

  @@map("sede")
}

model UserSedes {
  user    User @relation("UserSedeMember", fields: [user_id], references: [id])
  user_id Int

  sede    Sede @relation(fields: [sede_id], references: [id])
  sede_id Int

  assigned_by    User @relation("UserSedeAssignedBy", fields: [assigned_by_id], references: [id])
  assigned_by_id Int

  assigned_at DateTime @default(now()) @db.Timestamptz()

  @@id([user_id, sede_id])
  @@map("user_sede")
}

model Doctor {
  id            Int       @id @default(autoincrement())
  specialty     String
  slot_duration Int       @default(60)
  active        Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime? @db.Timestamptz()
  deleted_at    DateTime? @db.Timestamptz()

  sede    Sede @relation(fields: [sede_id], references: [id])
  sede_id Int

  user    User @relation(fields: [user_id], references: [id])
  user_id Int  @unique

  schedules    DoctorSchedule[]
  appointments Appointment[]

  @@map("doctor")
}

model Appointment {
  id Int @id @default(autoincrement())

  scheduled_date String
  scheduled_time String

  status     AppointmentStatus @default(PENDING)
  created_at DateTime          @default(now()) @db.Timestamptz()
  updated_at DateTime?         @db.Timestamptz()

  doctor    Doctor @relation(fields: [doctor_id], references: [id])
  doctor_id Int

  patient    Patient @relation(fields: [patient_id], references: [id])
  patient_id Int

  @@map("appointment")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED

  @@map("appointment_status")
}

model DoctorSchedule {
  id         Int    @id @default(autoincrement())
  day        Int
  start_time String
  end_time   String

  doctor    Doctor @relation(fields: [doctor_id], references: [id])
  doctor_id Int

  @@map("doctor_schedule")
}

model Patient {
  id             Int           @id @default(autoincrement())
  name           String
  last_name      String
  phone          String        @unique
  email          String        @unique
  age            Int
  documentNumber String
  documentType   String
  appointments   Appointment[]

  created_at DateTime  @default(now()) @db.Timestamptz()
  updated_at DateTime? @db.Timestamptz()
}
