enum UserRole {
  ADMIN
  USER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ResourceType {
  ORGANIZATION
  CLINIC
}

enum SubscriptionStatus {
  CANCELLED
  ACTIVE
}

enum Plan {
  BASIC
}
