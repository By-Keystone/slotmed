generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String   @unique
  name                String
  lastName            String   @map("last_name")
  phone               String
  passwordHash        String   @map("password_hash")
  role                UserRole @default(USER)
  confirmed           Boolean  @default(false)
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  accountId           String?  @map("account_id") @db.Uuid

  refreshTokens       RefreshToken[]
  doctor              Doctor?
  resourcesCreated    Resource[]
  resourceMemberships UserResourceMembership[] @relation(name: "user_membership")
  membershipsCreated  UserResourceMembership[] @relation(name: "memberships_created")

  @@map("user")
}

model Resource {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      ResourceType
  createdBy String       @map("created_by") @db.Uuid
  accountId String       @map("account_id") @db.Uuid

  organization        Organization?
  clinic              Clinic?
  resourceMemberships UserResourceMembership[]
  createdByUser       User                     @relation(fields: [createdBy], references: [id])
  account             Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("resource")
}

model Organization {
  resourceId String   @id @map("resource_id") @db.Uuid
  name       String   @unique
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  resource  Resource @relation(fields: [resourceId], references: [id])
  clinics   Clinic[]
  accountId String?  @db.Uuid

  @@map("organization")
}

model Clinic {
  resourceId     String   @id @map("resource_id") @db.Uuid
  name           String
  address        String
  phone          String
  organizationId String   @map("organization_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [resourceId])
  resource     Resource     @relation(fields: [resourceId], references: [id])

  @@map("clinic")
}

model UserResourceMembership {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  resourceId String   @map("resource_id") @db.Uuid
  accountId  String   @map("account_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  createdBy  String   @map("created_by") @db.Uuid
  role       UserRole @default(ADMIN)

  account       Account  @relation(fields: [accountId], references: [id])
  user          User     @relation(fields: [userId], references: [id], name: "user_membership")
  resource      Resource @relation(fields: [resourceId], references: [id])
  createdByUser User     @relation(fields: [createdBy], references: [id], name: "memberships_created")

  @@unique([userId, resourceId])
  @@map("user_resource_membership")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_token")
}

model Doctor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  specialty String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // appointments Appointment[]
  // schedules    DoctorSchedule[]

  @@map("doctor")
}

model Subscription {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId String             @unique @map("account_id") @db.Uuid
  status    SubscriptionStatus
  plan      Plan

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model Account {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  ownerId   String   @map("owner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  subscription            Subscription?
  userResourceMemberships UserResourceMembership[]
  resources               Resource[]

  @@map("account")
}

